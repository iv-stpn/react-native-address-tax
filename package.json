{
  "name": "react-address-tax",
  "version": "2.0.0",
  "description": "Reusable React component for international structured address input with VAT validation",
  "keywords": [
    "react",
    "address",
    "vat",
    "international",
    "form",
    "component"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/iv-stpn/react-address-tax.git"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./codes": {
      "import": {
        "types": "./dist/codes.d.ts",
        "default": "./dist/codes.js"
      },
      "require": {
        "types": "./dist/codes.d.cts",
        "default": "./dist/codes.cjs"
      }
    },
    "./utils": {
      "import": {
        "types": "./dist/utils.d.ts",
        "default": "./dist/utils.js"
      },
      "require": {
        "types": "./dist/utils.d.cts",
        "default": "./dist/utils.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build && bun run typecheck",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "bun run build && bun run typecheck && changeset publish",
    "ladle": "ladle serve",
    "ladle:build": "ladle build --base /react-address-tax/",
    "gen:geonames": "bun run scripts/gen-geonames.ts",
    "gen:level1": "bun run scripts/gen-level1-codes.ts",
    "gen:countries": "bun run scripts/gen-countries.ts",
    "gen:coverage": "bun run scripts/gen-coverage-table.ts",
    "prepare": "husky"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@ladle/react": "^5.1.1",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "latest",
    "@types/node": "^26",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "randexp": "^0.5.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^8",
    "vitest": "^4.1.9"
  }
}
