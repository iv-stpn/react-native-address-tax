{
  "name": "react-native-address-tax",
  "version": "1.0.1",
  "description": "Reusable React Native component for international structured address input with VAT validation (runs on web via react-native-web)",
  "keywords": [
    "react-native",
    "react-native-web",
    "react",
    "address",
    "tax",
    "international",
    "form",
    "component"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/iv-stpn/react-native-address-tax.git"
  },
  "type": "module",
  "exports": {
    "./AddressInput": {
      "import": {
        "types": "./dist/components/AddressInput.d.ts",
        "default": "./dist/components/AddressInput.js"
      },
      "require": {
        "types": "./dist/components/AddressInput.d.cts",
        "default": "./dist/components/AddressInput.cjs"
      }
    },
    "./AddressTaxInput": {
      "import": {
        "types": "./dist/components/AddressTaxInput.d.ts",
        "default": "./dist/components/AddressTaxInput.js"
      },
      "require": {
        "types": "./dist/components/AddressTaxInput.d.cts",
        "default": "./dist/components/AddressTaxInput.cjs"
      }
    },
    "./types": {
      "import": {
        "types": "./dist/components/types.d.ts",
        "default": "./dist/components/types.js"
      },
      "require": {
        "types": "./dist/components/types.d.cts",
        "default": "./dist/components/types.cjs"
      }
    },
    "./validation": {
      "import": {
        "types": "./dist/validation.d.ts",
        "default": "./dist/validation.js"
      },
      "require": {
        "types": "./dist/validation.d.cts",
        "default": "./dist/validation.cjs"
      }
    },
    "./codes": {
      "import": {
        "types": "./dist/codes.d.ts",
        "default": "./dist/codes.js"
      },
      "require": {
        "types": "./dist/codes.d.cts",
        "default": "./dist/codes.cjs"
      }
    },
    "./tax": {
      "import": {
        "types": "./dist/tax.d.ts",
        "default": "./dist/tax.js"
      },
      "require": {
        "types": "./dist/tax.d.cts",
        "default": "./dist/tax.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "typecheck": "tsc --noEmit && tsc -p demo/tsconfig.json && tsc -p src/__tests__/tsconfig.json",
    "prepublishOnly": "bun run build && bun run typecheck",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "bun run build && bun run typecheck && changeset publish",
    "demo": "vite --config demo/vite.config.ts",
    "demo:build": "vite --config demo/vite.config.ts build --base /react-native-address-tax/",
    "prepare": "node .husky/install.mjs"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-native": ">=0.70.0"
  },
  "peerDependenciesMeta": {
    "react-native": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@changesets/changelog-github": "0.7.0",
    "@changesets/cli": "2.31.0",
    "@iv-stpn/biome-config": "1.2.13",
    "@testing-library/jest-dom": "^6",
    "@testing-library/react": "^16",
    "@testing-library/user-event": "^14",
    "@types/bun": "latest",
    "@types/node": "^26",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6",
    "biome-drizzle-best-practices-plugin": "2.0.0",
    "biome-one-liner-plugin": "1.3.3",
    "biome-react-best-practices-plugin": "2.0.0",
    "biome-typescript-best-practices-plugin": "1.2.1",
    "husky": "^9",
    "jsdom": "^29",
    "react": "^19",
    "react-dom": "^19",
    "react-native": "0.86.0",
    "react-native-web": "^0.21",
    "tsup": "^8",
    "typescript": "^7",
    "vite": "^8",
    "vitest": "^4"
  },
  "dependencies": {
    "country-data-ts": "^0.1.0"
  }
}
